# ============ DATABASE ============
DATABASE_URL="postgresql://user:password@ep-xxx.neon.tech/neondb?sslmode=require"

# ============ STORE ============
STORE_SLUG="kate-barber"
NEXT_PUBLIC_BASE_URL="https://your-domain.com"

# ============ ADMIN ============
ADMIN_EMAIL="admin@your-store.com"
ADMIN_PASSWORD="change_me_before_production"
ADMIN_SECRET="generate_random_32_char_string_here"

# ============ FILE STORAGE (Vercel Blob) ============
BLOB_READ_WRITE_TOKEN=""

# ============ REGION & LOCALE ============
REGION_BUNDLE="SK"

# ============ AI (optional — for RAG assistant) ============
# OPENAI_API_KEY="sk-..."

# ============ CRON (optional — for archiving past appointments) ============
# CRON_SECRET="generate_random_secret_here"

# ============ MODULES (toggle true/false) ============
NEXT_PUBLIC_ENABLE_BOOKING=true
NEXT_PUBLIC_ENABLE_WHATSAPP_BOOKING=true
NEXT_PUBLIC_ENABLE_PAYMENT=false
NEXT_PUBLIC_ENABLE_DEPOSIT=false
NEXT_PUBLIC_ENABLE_SMS=false
NEXT_PUBLIC_ENABLE_WHATSAPP_API=false
NEXT_PUBLIC_ENABLE_DIGITAL=false
NEXT_PUBLIC_ENABLE_COURSES=false
NEXT_PUBLIC_ENABLE_TEAM=true
NEXT_PUBLIC_ENABLE_GALLERY=true

# static = hardcoded testimonials | dynamic = DB with admin approval panel
NEXT_PUBLIC_REVIEWS_MODE=static

# ============ DESIGN ============
NEXT_PUBLIC_THEME=dark
# Options: dark | light | warm | navy

# ============ STRIPE (optional — enable online payments) ============
# STRIPE_SECRET_KEY="sk_test_..."
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."

# ============ INTEGRATIONS (optional) ============
# TWILIO_ACCOUNT_SID="..."
# TWILIO_AUTH_TOKEN="..."
# TWILIO_FROM_NUMBER="+1..."
# WHATSAPP_API_TOKEN="..."
# WHATSAPP_PHONE_NUMBER_ID="..."
